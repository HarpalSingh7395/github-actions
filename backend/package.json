{
    "name": "backend",
    "version": "1.0.0",
    "description": "Node.js Express API backend",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint src/**/*.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.0.18",
        "supertest": "^7.2.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}